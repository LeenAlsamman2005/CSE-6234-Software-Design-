@{ ViewData["Title"] = "Login"; }

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h3 class="text-center mb-4"><i class="bi bi-box-arrow-in-right me-2"></i>Login</h3>
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" required />
                    </div>
                    <button class="btn btn-primary w-100">Sign In</button>
                </form>
                <hr />
                <p class="text-center small">No account? <a asp-action="Register">Register here</a></p>
                <div class="mt-3 p-2 bg-light rounded small">
                    <strong>Demo Logins:</strong><br />
                    Admin: admin@ebs.com / admin123<br />
                    Organizer: leen@ebs.com / organizer123<br />
                    Customer: fatima@ebs.com / customer123
                </div>
            </div>
        </div>
    </div>
</div>
