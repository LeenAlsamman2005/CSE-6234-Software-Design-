@model List<EventBookingSystem.Models.Booking>
@{ ViewData["Title"] = "All Bookings"; }

<h3><i class="bi bi-list-ul me-2"></i>All Bookings</h3>

<table class="table bg-white shadow-sm align-middle">
    <thead class="table-light">
        <tr><th>Ref</th><th>Event</th><th>Customer</th><th>Date</th><th>Total</th><th>Status</th><th>Payment</th></tr>
    </thead>
    <tbody>
    @foreach (var b in Model)
    {
        <tr>
            <td><code>B@(b.BookingId.ToString("D5"))</code></td>
            <td>@b.Event?.Title</td>
            <td>@b.Customer?.Name</td>
            <td>@b.BookingDate.ToString("dd MMM yyyy HH:mm")</td>
            <td>RM @b.TotalAmount.ToString("F2")</td>
            <td><span class="badge bg-secondary">@b.Status</span></td>
            <td>@(b.Payment?.Status.ToString() ?? "-")</td>
        </tr>
    }
    </tbody>
</table>
