@model List<EventBookingSystem.Models.User>
@{ ViewData["Title"] = "Manage Users"; }

<h3><i class="bi bi-people me-2"></i>Users</h3>

<table class="table bg-white shadow-sm align-middle">
    <thead class="table-light">
        <tr><th>ID</th><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Created</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.UserId</td>
            <td>@u.Name</td>
            <td>@u.Email</td>
            <td><span class="badge bg-primary">@u.Role</span></td>
            <td>
                @if (u.IsActive) { <span class="badge bg-success">Active</span> }
                else { <span class="badge bg-danger">Inactive</span> }
            </td>
            <td>@u.CreatedAt.ToString("dd MMM yyyy")</td>
            <td>
                @if (u.Role != EventBookingSystem.Models.UserRole.Admin)
                {
                    <form method="post" asp-action="ToggleUser" asp-route-id="@u.UserId" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-warning">
                            @(u.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
