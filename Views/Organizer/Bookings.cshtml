@model List<EventBookingSystem.Models.Booking>
@{ ViewData["Title"] = "Bookings"; }

<h3><i class="bi bi-list-check me-2"></i>Bookings for My Events</h3>

@if (!Model.Any())
{
    <div class="alert alert-info">No bookings yet.</div>
}
else
{
    <table class="table bg-white shadow-sm align-middle">
        <thead class="table-light">
            <tr><th>Ref</th><th>Event</th><th>Customer</th><th>Date</th><th>Tickets</th><th>Total</th><th>Status</th></tr>
        </thead>
        <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td><code>B@(b.BookingId.ToString("D5"))</code></td>
                <td>@b.Event?.Title</td>
                <td>@b.Customer?.Name</td>
                <td>@b.BookingDate.ToString("dd MMM yyyy")</td>
                <td>@b.Tickets.Count</td>
                <td>RM @b.TotalAmount.ToString("F2")</td>
                <td><span class="badge bg-secondary">@b.Status</span></td>
            </tr>
        }
        </tbody>
    </table>
}
