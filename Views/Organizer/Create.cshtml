@model EventBookingSystem.Models.Event
@{
    ViewData["Title"] = "New Event";
    var cats = ViewBag.Categories as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<h3><i class="bi bi-plus-circle me-2"></i>Create Event</h3>
<form method="post" class="card shadow-sm border-0 p-4">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Title</label>
            <input asp-for="Title" class="form-control" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Category</label>
            <select asp-for="Category" class="form-select">
                @foreach (var c in cats) { <option>@c</option> }
            </select>
        </div>
        <div class="col-md-8">
            <label class="form-label">Venue</label>
            <input asp-for="Venue" class="form-control" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Date</label>
            <input asp-for="EventDate" type="datetime-local" class="form-control" required />
        </div>
        <div class="col-12">
            <label class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
    </div>

    <hr />
    <h5>Ticket Categories</h5>
    <p class="text-muted small">Add at least one. Default rows shown — clear name to skip.</p>
    <table class="table">
        <thead><tr><th>Name</th><th>Price (RM)</th><th>Quantity</th></tr></thead>
        <tbody>
            @for (int i = 0; i < 3; i++)
            {
                <tr>
                    <td><input name="catName" class="form-control" placeholder="e.g. VIP" /></td>
                    <td><input name="catPrice" type="number" step="0.01" min="0" class="form-control" value="0" /></td>
                    <td><input name="catQty" type="number" min="0" class="form-control" value="0" /></td>
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-primary"><i class="bi bi-save"></i> Create Event</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>
