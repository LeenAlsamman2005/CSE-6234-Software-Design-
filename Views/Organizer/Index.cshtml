@model List<EventBookingSystem.Models.Event>
@{
    ViewData["Title"] = "Organizer Dashboard";
    var report = ViewBag.Report as EventBookingSystem.Services.OrganizerReport;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-easel me-2"></i>My Events</h3>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Event</a>
</div>

@if (report != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="stat-card"><div class="lbl">Events</div><div class="num">@report.TotalEvents</div></div></div>
        <div class="col-md-4"><div class="stat-card"><div class="lbl">Bookings</div><div class="num">@report.TotalBookings</div></div></div>
        <div class="col-md-4"><div class="stat-card"><div class="lbl">Revenue</div><div class="num">RM @report.TotalRevenue.ToString("F2")</div></div></div>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">You have not created any events yet.</div>
}
else
{
    <table class="table bg-white shadow-sm align-middle">
        <thead class="table-light">
            <tr><th>Title</th><th>Venue</th><th>Date</th><th>Status</th><th>Categories</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var ev in Model)
        {
            <tr>
                <td>@ev.Title</td>
                <td>@ev.Venue</td>
                <td>@ev.EventDate.ToString("dd MMM yyyy")</td>
                <td><span class="badge bg-secondary">@ev.Status</span></td>
                <td>@ev.Categories.Count</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@ev.EventId">Edit</a>
                    <form method="post" asp-action="Delete" asp-route-id="@ev.EventId" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Delete this event?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
