@{
    var name = Context.CurrentUserName();
    var role = Context.CurrentRole();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Event Booking System</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark bg-gradient-primary shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
            <i class="bi bi-ticket-perforated-fill me-1"></i> EventBook
        </a>
        <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="nav" class="collapse navbar-collapse">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" asp-controller="Events" asp-action="Index">Browse Events</a></li>
                @if (role == UserRole.Customer)
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Bookings" asp-action="History">My Bookings</a></li>
                }
                @if (role == UserRole.Organizer)
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Organizer" asp-action="Index">My Events</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Organizer" asp-action="Bookings">Bookings</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Organizer" asp-action="Reports">Reports</a></li>
                }
                @if (role == UserRole.Admin)
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Users">Users</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Bookings">All Bookings</a></li>
                }
            </ul>
            <ul class="navbar-nav">
                @if (Context.IsAuthenticated())
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Notifications">
                            <i class="bi bi-bell-fill"></i>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> @name <span class="badge bg-light text-dark ms-1">@role</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Logout</a></li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                    <li class="nav-item"><a class="btn btn-light btn-sm ms-2" asp-controller="Account" asp-action="Register">Sign Up</a></li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4">
    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@ok
            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@err
            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</main>

<footer class="footer mt-auto py-3 bg-dark text-light">
    <div class="container text-center small">
        &copy; @DateTime.UtcNow.Year EventBook &middot; CSE 6234 Software Design Prototype &middot;
        Patterns: Factory, Strategy, Observer, Facade
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
